#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(git rev-parse --show-toplevel)"
cd "$REPO_DIR"

echo "🚀 post-commit: pushing to origin/main..."
if ! git push origin main; then
  echo "⚠️ push rejected, syncing with remote and retrying..."
  git -c core.hooksPath=/dev/null pull --rebase --autostash origin main
  git push origin main
fi

echo "🚀 post-commit: deploying to production..."
"$REPO_DIR/scripts/deploy_remote.sh"

echo "✅ post-commit done"
